# Production Environment
NODE_ENV=production
VITE_APP_VERSION=4.5.0
VITE_APP_NAME=Carmen Web

# API Configuration
VITE_API_URL=https://api.carmen-web.example.com
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false

# Authentication
VITE_AUTH_STORAGE_KEY=carmen_auth_token
VITE_REFRESH_TOKEN_KEY=carmen_refresh_token

# Monitoring
# VITE_SENTRY_DSN=

# External Services
# VITE_GOOGLE_ANALYTICS_ID=
